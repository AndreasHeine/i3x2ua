# Local environment template for i3x_server
# Source of truth: i3x_server/config/settings.py, i3x_server/main.py, run.py

# Network binding (used by run.py only)
I3X_HOST=0.0.0.0
I3X_PORT=8000

# OPC UA connection
# For Docker Compose, if your OPC UA server runs on the host machine,
# use host.docker.internal instead of 127.0.0.1.
I3X_OPCUA_ENDPOINT=opc.tcp://opcua.umati.app:4843
I3X_OPCUA_USERNAME=
I3X_OPCUA_PASSWORD=

# OPC UA security
# Example mode values: None, Sign, SignAndEncrypt
I3X_OPCUA_SECURITY_MODE=SignAndEncrypt
# Example policy values: Basic256Sha256, Aes128_Sha256_RsaOaep, etc.
I3X_OPCUA_SECURITY_POLICY=Basic256Sha256
# Sample client certificate bundle for encrypted OPC UA testing:
# certs/opcua-client-sample/client-cert.pem
# certs/opcua-client-sample/client-key.pem
I3X_OPCUA_CLIENT_CERT_PATH=./certs/opcua-client-sample/client-cert.pem
I3X_OPCUA_CLIENT_KEY_PATH=./certs/opcua-client-sample/client-key.pem
I3X_OPCUA_CLIENT_KEY_PASSWORD=
I3X_OPCUA_SERVER_CERT_PATH=

# OPC UA/model performance tuning
I3X_OPCUA_BROWSE_CONCURRENCY=128
I3X_OPCUA_METADATA_CACHE_TTL_SECONDS=300
I3X_OPCUA_CONNECTION_MONITOR_INTERVAL_SECONDS=5
I3X_MODEL_REFRESH_INTERVAL_SECONDS=60

# Startup/model preload behavior (true/false)
I3X_MODEL_PRELOAD_ON_STARTUP=true
I3X_MODEL_PRELOAD_BLOCKING=false
I3X_FAIL_STARTUP_ON_MODEL_PRELOAD_ERROR=false

# Subscription behavior
# Set to false to disable seeding current values into a subscription on registration
I3X_SUBSCRIPTIONS_INITIAL_VALUES=true
I3X_SUBSCRIPTION_INTERVAL_SECONDS=5
I3X_SUBSCRIPTION_MAX_UPDATES=10000
I3X_SUBSCRIPTION_TTL_SECONDS=300

# Optional v1 object-type enrichment behavior
I3X_ENABLE_TYPE_BROWSENAME_LOOKUP=0
I3X_TYPE_BROWSENAME_LOOKUP_TIMEOUT_S=0.05
I3X_TYPE_BROWSENAME_LOOKUP_MAX=20

# Logging
I3X_LOG_LEVEL=INFO

# CORS allowed origins (JSON array of strings; empty = CORS disabled)
# Example for the i3X Explorer or local dev:
# I3X_CORS_ALLOWED_ORIGINS=["https://explorer.i3x.dev"]
# I3X_CORS_ALLOWED_ORIGINS=["*"]
I3X_CORS_ALLOWED_ORIGINS=[]

# OpenTelemetry tracing (requires 'otel' extras installed)
I3X_OTEL_ENABLED=false
I3X_OTEL_SERVICE_NAME=i3x2ua
# I3X_OTEL_OTLP_ENDPOINT=http://localhost:4318
I3X_OTEL_OTLP_ENDPOINT=

# MCP support (0/1; disabled by default)
I3X_ENABLE_MCP=0

# Dev/test convenience: skip OPC UA connect on startup (0/1)
I3X_SKIP_OPCUA_CONNECT=0

# Debug: verbose SSE stream logging (0/1)
I3X_DEBUG_SUBSCRIPTION_STREAM=0

# Uvicorn / run.py options
I3X_RELOAD=0
# Loop implementation: auto, asyncio, uvloop (empty = auto)
I3X_UVICORN_LOOP=

# Docker mount path for OPC UA client/server cert files used by i3x2ua container
I3X_OPCUA_CERTS_DIR=./certs

# Nginx reverse proxy HTTPS (docker-compose)
# Generate development certs with:
# uv run python scripts/generate_https_dev_cert.py
NGINX_HTTPS_ENABLED=0
NGINX_SERVER_NAME=localhost
NGINX_HTTPS_REDIRECT_PORT=8443
NGINX_SSL_CERTS_DIR=./certs
NGINX_SSL_CERTIFICATE=/etc/nginx/certs/https-sample/fullchain.pem
NGINX_SSL_CERTIFICATE_KEY=/etc/nginx/certs/https-sample/privkey.pem
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_UPSTREAM_HOST=i3x2ua
NGINX_UPSTREAM_PORT=8000
NGINX_BASIC_AUTH_ENABLED=0
NGINX_BASIC_AUTH_USER=
NGINX_BASIC_AUTH_PASSWORD=
NGINX_BASIC_AUTH_REALM=i3x2ua
