{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/overrides/schema.json",
  "title": "MCP Overrides",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "tools": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/toolOverride"
      }
    },
    "prompts": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/promptOverride"
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "tools",
    "prompts"
  ],
  "additionalProperties": false,
  "$defs": {
    "toolOverride": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "normal",
            "high"
          ]
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "description"
      ],
      "additionalProperties": false
    },
    "promptOverride": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "template": {
          "type": "string"
        }
      },
      "required": [
        "description",
        "inputs",
        "template"
      ],
      "additionalProperties": false
    }
  }
}
